# E2E test site template. This is the primary live-subscription validation of
# the siteops engine and the scalekit samples it drives.
#
# Rendered at runtime (workflow or local shell) by `scripts/render-e2e-site.py`
# into a writable directory; that directory is then supplied via
# SITEOPS_EXTRA_SITES_DIRS so the orchestrator picks this site up without it
# living under workspaces/*/sites/.
#
# Inheritance: base-site.yaml -> this file.
# Why inherit base-site.yaml directly: exercises the full production merge path
# (trusted-dir lookup, inherits resolution, deployOptions defaults, parameter
# precedence) against a real Azure target.
#
# Site name is runtime-unique (${E2E_SITE_NAME}). The orchestrator does not
# reject same-named sites that appear in both workspace sites/ and an extra
# trusted dir, so a fixed name like "e2e-test" could silently merge with an
# operator-owned site of the same name. A per-run unique name avoids this.
#
# deployOptions are pinned explicitly (not inherited) so changes to
# base-site.yaml defaults can never silently alter the E2E run cost, runtime,
# or scope. Individual test phases that specifically exercise a disabled path
# can override this via their own site file.
#
# Expected environment variables (all required at render time):
#   E2E_SITE_NAME        Runtime-unique site name (e.g. e2e-<run_id>-<attempt>-<ver>)
#   E2E_SUBSCRIPTION     Azure subscription ID
#   E2E_RESOURCE_GROUP   Resource group (operator-supplied in persistent mode; workflow-created in ephemeral)
#   E2E_LOCATION         Azure region (ephemeral: workflow input; persistent: from `az group show`)
#   E2E_CLUSTER_NAME     Arc-connected cluster name created earlier in the run
#   E2E_AIO_RELEASE      AIO release selector (drives versioned-templates path)

apiVersion: siteops/v1
kind: Site
name: ${E2E_SITE_NAME}
inherits: base-site.yaml

subscription: "${E2E_SUBSCRIPTION}"
resourceGroup: "${E2E_RESOURCE_GROUP}"
location: "${E2E_LOCATION}"

labels:
  environment: e2e
  managedBy: siteops-e2e
  country: US
  city: E2E

properties:
  aioRelease: "${E2E_AIO_RELEASE}"
  deployOptions:
    enableGlobalSite: false
    enableEdgeSite: false
    enableSecretSync: true
    enableCertManager: true

parameters:
  clusterName: "${E2E_CLUSTER_NAME}"
  brokerConfig:
    memoryProfile: Low
  defaultDataflowInstanceCount: 1
